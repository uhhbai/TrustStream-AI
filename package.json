{
  "name": "truststream-ai-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:server": "pnpm --filter @truststream/server dev",
    "dev:extension": "pnpm --filter @truststream/extension dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "prisma:generate": "pnpm --filter @truststream/server prisma:generate",
    "prisma:migrate": "pnpm --filter @truststream/server prisma:migrate",
    "prisma:seed": "pnpm --filter @truststream/server prisma:seed"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
